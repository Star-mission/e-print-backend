# 环境变量示例文件
# 复制此文件为 .env 并根据实际情况修改

# ==================== 数据库配置 ====================

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=E_Bench
MYSQL_USERNAME=eprint
MYSQL_PASSWORD=eprint123

# MongoDB 配置
MONGODB_URI=mongodb://localhost:27017/E_Bench_Logs
MONGODB_DATABASE=E_Bench_Logs

# ==================== 服务器配置 ====================

# 服务器端口
SERVER_PORT=3000

# ==================== 文件上传配置 ====================

# 文件上传目录（生产环境）
FILE_UPLOAD_DIR=/var/eprint/uploads

# ==================== 黑湖（Blacklake）Token 配置 ====================
#
# 服务启动时会调用黑湖登录接口获取 token，并保存到 MySQL 表 external_tokens。
# application-dev.yml / application-prod.yml 中会将 external.token.phone/password 映射为以下环境变量。
#
BLACKLAKE_PHONE=
BLACKLAKE_PASSWORD=

# ==================== 其他配置 ====================

# 日志级别（DEBUG, INFO, WARN, ERROR）
LOG_LEVEL=INFO
